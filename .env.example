# Copia a .env.local — solo variables públicas (van embebidas en el build de cPanel)
VITE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Cloudinary — optimización de imágenes subidas por usuarios
# Crea un upload preset "unsigned" en: Cloudinary Dashboard > Settings > Upload > Upload Presets
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=ai-da-unsigned

# Supabase Edge Functions (mismos valores — subir con supabase secrets set)
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_UPLOAD_PRESET=ai-da-unsigned
# REPLICATE_API_TOKEN=r8_...
# STABILITY_API_KEY=sk-...

# Redirect tras confirmar correo (debe coincidir con Supabase Auth → URL Configuration)
# VITE_AUTH_REDIRECT_URL=https://allinremodeling.us/ai/

# Opcional: override de la URL del chat
# VITE_CHAT_API_URL=https://TU_PROJECT_REF.supabase.co/functions/v1/chat
